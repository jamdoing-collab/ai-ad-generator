# 服务器配置
PORT=3000
NODE_ENV=development

# CORS 配置（逗号分隔多个域名；生产环境必须配置）
ALLOWED_ORIGINS=

# grsai API 配置
OPENAI_API_KEY=your-grsai-api-key-here
OPENAI_BASE_URL=https://grsai.dakka.com.cn
OPENAI_MODEL=gpt-image-2

# 公网可访问的基础 URL（用于参考图 URL 构造，留空则从请求头推断）
PUBLIC_BASE_URL=

# 图床 API Token（imgbb）
IMAGE_HOST_TOKEN=

# JWT 密钥（生产环境请轮换为新的随机值）
JWT_SECRET=your-secret-key-change-in-production

# JWT 回退密钥（仅用于兼容旧 token，生产环境应留空）
JWT_FALLBACK_SECRETS=

# 管理员用户名（逗号分隔，启动时自动同步权限）
ADMIN_USERNAMES=

# 点数配置
NEW_USER_POINTS=10
POINTS_PER_GENERATE=1
POINTS_PER_GENERATE_HD=2
POINTS_PER_GENERATE_4K=3

# 邀请奖励配置
INVITE_NEW_USER_POINTS=2
INVITE_FIRST_GENERATE_POINTS=2
