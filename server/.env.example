# 服务器配置
PORT=3000
NODE_ENV=development

# CORS 配置（逗号分隔多个域名，留空允许所有）
ALLOWED_ORIGINS=

# grsai API 配置
OPENAI_API_KEY=your-grsai-api-key-here
OPENAI_BASE_URL=https://grsai.dakka.com.cn
OPENAI_MODEL=gpt-image-2

# 公网可访问的基础 URL（用于参考图 URL 构造，留空则从请求头推断）
PUBLIC_BASE_URL=

# 图床 API Token（imgbb）
IMAGE_HOST_TOKEN=

# JWT 密钥（生产环境请更换为复杂的随机字符串）
JWT_SECRET=your-secret-key-change-in-production

# 管理员用户名（逗号分隔，启动时自动同步权限）
ADMIN_USERNAMES=

# 点数配置
NEW_USER_POINTS=10
POINTS_PER_GENERATE=1
POINTS_PER_GENERATE_HD=2
POINTS_PER_GENERATE_4K=3
